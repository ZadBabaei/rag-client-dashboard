# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rag_dashboard?schema=public"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Anthropic (optional — used if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER="openai"

# Server
PORT=3001
FRONTEND_URL="http://localhost:5173"
